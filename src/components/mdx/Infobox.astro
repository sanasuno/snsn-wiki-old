---
import { readFileSync, existsSync } from 'node:fs';
import { resolve } from 'node:path';
import { loadDataJson } from '@lib/jsonDataCache';

interface Field {
    label: string
    value: string
}
interface InfoboxData {
    title?: string
    image?: string
    body?: string
    fields?: Field[]
}

interface Props {
    src?: string // JSONから読む場合
    id?: string // 配列から特定の要素を読み込む場合
    title?: string // 直接指定する場合
    image?: string
    fields?: Field[]
}
const { src, id, ...direct } = Astro.props as Props;

let data: InfoboxData = {}

// キャッシュを使用したJSON読み込み
type LoadResult = { ok: true; data: any } | { ok: false; error: string }
const jsonCache = new Map<string, any>();

/**
 * JSONファイルを読み込む
 * @param src JSONファイルのパス
 * @returns 読み込んだデータまたはエラー
 */
function loadJson(src: string): LoadResult {
    const cached = jsonCache.get(src);
    if (cached) return cached;

    const jsonPath = resolve(process.cwd(), `src/data/${src}.json`)
    if (!existsSync(jsonPath)) {
        const result: LoadResult = {
            ok: false,
            error: `JSON file not found: ${jsonPath}`
        }
        jsonCache.set(src, result);
        return result;
    }
    let result: LoadResult;
    try {
        result = {
            ok: true,
            data: JSON.parse(readFileSync(jsonPath, 'utf-8'))
        }
    }
    catch (error) {
        result = {
            ok: false,
            error: `Failed to parse JSON: src/data/${src}.json`
        };
    }
    jsonCache.set(src, result);
    return result;
}

if (src) {
    const result = loadJson(src)
    if (result.ok) {
        const jsonData = result.data;
        if (Array.isArray(jsonData) && id) {
            const found = jsonData.find(item => item.id === id)
            if (found) {
                data = {
                    title: found.name,
                    fields: Object.entries(found)
                        .filter(([key]) => key !== 'id' && key !== 'name')
                        .map(([label, value]) => ({
                            label,
                            value: String(value)
                        }))
                }
            } else {
                data = { title: `Not found: id=${id} in ${src}.json` }
            }
        } else {
            data = jsonData
        }
    } else {
        data = { title: result.error }
    }
}

const title = direct.title ?? data.title ?? ''
const image = direct.image ?? data.image ?? ''
const fields = direct.fields ?? data.fields ?? []
const body = data.body
---
<aside class="infobox">
    {image && <img src={image} alt={title ?? ''} class="infobox-image" />}
    {title && <h3 class="infobox-title">{title}</h3>}
    {Astro.slots.has('default')
        ? <div class="infobox-body"><slot /></div>
        : body && <div class="infobox-body">{body}</div>
    }
    {fields && fields.map(({ label, value }) => (
        <div class="infobox-field">
            <dt class="infobox-field-label">{label}</dt>
            <dd class="infobox-field-value">{value}</dd>
        </div>
    ))}
</aside>
<style>
    .infobox {
        display: block;
        float: right;
        clear: right;
        width: 240px;
        margin: 0 0 16px 24px;
        padding: 16px;
        background-color: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
    }
    
    .infobox-image {
        width: 100%;
        height: auto;
        margin-bottom: 12px;
        border-radius: var(--radius-sm);
    }
    .infobox-title {
        display: flex;
        justify-content: center;
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 8px !important;
    }
    .infobox-body {
        color: var(--color-text-muted);
        margin: 0 0 8px;
    }
    .infobox-field {
        display: flex;
        gap: 8px;
        border-top: 1px solid var(--color-border);
        padding: 4px 0;
    }
    .infobox-field-label {
        font-weight: 600;
        min-width: 80px;
        color: var(--color-text-muted);
    }
    .infobox-field-value {
        margin: 0;
        color: var(--color-text);
    }
</style>