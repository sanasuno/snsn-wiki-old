---
/**
 * @components/MainContent.astro
 * メインコンテンツを定義するコンポーネント
 * @param {string} title ページタイトル
 * @param {Locale} locale ロケール
 * @param {string} localeBaseUrl ロケールベースURL
 * @param {string} currentPath 現在のパス
 * @param {string} category カテゴリ
 * @param {string[]} tags タグ
 * @param {Date} date 作成日
 * @param {Date} updated 更新日
 * @param {boolean} isFallbackContent フォールバックコンテンツかどうか
 * @param {boolean} isWikiPage ウィキページかどうか
 * @param {boolean} showMeta メタ情報を表示するかどうか
 */

import { t, type Locale, formatDate } from '@i18n/i18n.config';
interface Props {
    title: string;
    localeBaseUrl: string;
    locale: Locale;
    currentPath: string;
    categories?: string[];
    tags?: string[];
    date?: Date;
    updated?: Date;
    isFallbackContent?: boolean;
    isWikiPage?: boolean;
    showMeta?: boolean;
}

const {
    title,
    localeBaseUrl,
    locale,
    currentPath,
    categories,
    tags = [],
    date,
    updated,
    isFallbackContent = false,
    isWikiPage = false,
    showMeta = true
} = Astro.props;

// メタ情報欄に表示するカテゴリ：末尾の1つのみ（例: ['tech', 'astro'] → 'astro'）
const leafCategory = categories && categories.length > 0
    ? { name: categories[categories.length - 1], path: categories.join('/') }
    : null;

// パンくずリストの型
type Crumb = {
    label: string; // パンくずのラベル
    href: string; // パンくずのリンク先
    categorySegment?: string | undefined; // カテゴリセグメント
}

function stripWikiPrefix(path: string, wikiPrefix: string, localeBaseUrl: string): string {
    if (path.startsWith(wikiPrefix)) {
        return path.substring(wikiPrefix.length);
    }
    const wikiIdx = path.indexOf('/wiki/');
    if (wikiIdx !== -1) {
        return path.slice(wikiIdx + '/wiki/'.length);
    }
    return path.slice(localeBaseUrl.length);
}

/**
 * パンくずリストを構築する
 * @param path パス
 * @param title タイトル
 * @param localeBaseUrl ロケールベースURL
 * @param isWikiPage ウィキページかどうか
 * @returns パンくずリスト
 */
function buildCrumbs(path: string, title: string, localeBaseUrl: string, isWikiPage: boolean): Crumb[] {
    // ウィキページの場合、カテゴリを抽出してパンくずリストを構築する
    if (isWikiPage) {
        // ウィキページのパスからカテゴリを抽出
        // 例: /ja/wiki/tech/astro → ['tech', 'astro']
        const wikiPrefix = `${localeBaseUrl}/wiki`;
        if (!path.startsWith(wikiPrefix) && import.meta.env.DEV) {
            console.warn(`Path ${path} does not start with ${wikiPrefix}`);
        }
        const strippedPath = stripWikiPrefix(path, wikiPrefix, localeBaseUrl);
        const segments = strippedPath.split('/').filter(Boolean);
        // ルートからカテゴリまでのパンくずリストを構築
        const crumbs: Crumb[] = [
            {
                label: t('nav.home', locale),
                href: localeBaseUrl
            }
        ]
        let categoryAccumulated = '';

        segments.forEach((segment, index) => {
            const isLast = index === segments.length - 1; // 最後のセグメントかどうか
            // カテゴリを積み上げながらパンくずリストを構築
            categoryAccumulated += (categoryAccumulated ? '/' : '') + segment;
            crumbs.push({
                label: isLast ? title : segment, // 最後のセグメントはタイトルを表示
                href: isLast ? path : `${localeBaseUrl}/category/${categoryAccumulated}`, // 最後のセグメントは現在のページのパスを設定
                categorySegment: !isLast ? segment : undefined, // 最後のセグメント以外はカテゴリセグメントを設定
            });
        });
        return crumbs;
    } else { // 通常ページの場合
        // ページパスからカテゴリを抽出
        // 例: /ja/about → []
        // 例: /ja/services/web-design → ['services']
        const strippedPath = path.startsWith(localeBaseUrl)
            ? path.slice(localeBaseUrl.length)
            : path;
        const segments = strippedPath.split('/').filter(Boolean);
        // ルートからカテゴリまでのパンくずリストを構築
        const crumbs: Crumb[] = [{
            label: t('nav.home', locale),
            href: localeBaseUrl
        }];
        let accumulated = localeBaseUrl;
        segments.forEach((segment, index) => {
            // カテゴリを積み上げながらパンくずリストを構築
            accumulated += `/${segment}`;
            const isLast = index === segments.length - 1; // 最後のセグメントかどうか
            crumbs.push({
                label: isLast ? title : segment, // 最後のセグメントはタイトルを表示
                href: accumulated, // パンくずリストのリンク先
            });
        });
        return crumbs;
    }
}

// パンくずリストを構築
const crumbs: Crumb[] = buildCrumbs(currentPath, title, localeBaseUrl, isWikiPage);
---
<main class="main-content" id="main-content">
    <!-- フォールバックコンテンツ警告 -->
    {isFallbackContent && (
        <div class="fallback-warning">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>{t('fallback.warning', locale)}</span>
        </div>
    )}
    {showMeta && (
        <header class="page-header">
            <!-- パンくずリスト -->
            <nav class="breadcrumb">
                <ol class="breadcrumbs">
                    {crumbs.map((crumb, index) => {
                        const isHome = index === 0; // ホームページかどうか
                        const isLast = index === crumbs.length - 1; // 最後のパンくずかどうか
                        const isCategorySegment = !isLast && !isHome && isWikiPage; // カテゴリセグメントかどうか
                        return (
                            <>
                                <li class:list={[{ 'breadcrumb__current': isLast }]} aria-current={isLast ? 'page' : undefined}>
                                    {isHome ? ( // ホームページの場合、最後のセグメントかどうかでリンクの有無を分ける
                                        isLast
                                            ? <> 
                                                <i class="fa-solid fa-house" />
                                                <span>{crumb.label}</span>
                                            </>
                                            : <>
                                                <i class="fa-solid fa-house" />
                                                <a href={crumb.href}>{crumb.label}</a>
                                            </>
                                        ) : isLast ? ( // 最後のセグメントの場合、リンクなし
                                            <>
                                                <i class="fa-regular fa-file" />
                                                <span>{crumb.label}</span>
                                            </>
                                        ) : isCategorySegment ? ( // カテゴリセグメントの場合、カテゴリページへのリンク
                                            <>
                                                <!-- カテゴリページへのリンク -->
                                                <i class="fa-solid fa-folder" />
                                                <a href={crumb.href}>
                                                    {t(`category.${crumb.label}` as any, locale) !== `category.${crumb.label}` 
                                                        ? t(`category.${crumb.label}` as any, locale) 
                                                        : crumb.label}
                                                </a>
                                            </>
                                        ) : ( // その他のセグメントの場合、そのままリンク
                                            <>
                                                <i class="fa-regular fa-file" />
                                                <a href={crumb.href}>{crumb.label}</a>
                                            </>
                                        )
                                    }
                                </li>
                                {!isLast && ( // 最後のセグメント以外には区切り記号を表示
                                    <li class="breadcrumb__separator" aria-hidden="true">
                                        <i class="fa-solid fa-chevron-right" />
                                    </li>
                                )}
                            </>
                        );
                    })}
                </ol>
            </nav>
            <!-- タイトル -->
            <h1 class="page-title">{title}</h1>
            <!-- メタ情報 -->
            <div class="page-meta">
                {leafCategory && (
                    <!-- カテゴリリンク -->
                    <div class="page-category">
                        <a href={`${localeBaseUrl}/category/${leafCategory.path}`}>
                            <i class="fa-regular fa-folder" />
                            {t(`category.${leafCategory.name}` as any, locale) !== `category.${leafCategory.name}` 
                                ? t(`category.${leafCategory.name}` as any, locale) 
                                : leafCategory.name}
                        </a>
                    </div>
                )}
                {(date || updated) && (
                    <!-- 日付情報 -->
                    <div class="page-meta-dates">
                        {date && (
                            <span class="page-date">
                                <i class="fa-regular fa-calendar-plus" />
                                {t("meta.created", locale)}: {formatDate(date, locale)}
                            </span>
                        )}
                        {updated && (
                            <span class="page-date">
                                <i class="fa-solid fa-clock-rotate-left" />
                                {t("meta.updated", locale)}: {formatDate(updated, locale)}
                            </span>
                        )}
                    </div>
                )}
            </div>
        </header>
    )}
    <article class="article-content">
        <slot />
        <!-- タグ -->
        {tags.length > 0 && (
            <div class="page-tags">
                {tags.map(tag => (
                    <a href={`${localeBaseUrl}/tag/${encodeURIComponent(tag)}`} class="tag">
                        #{tag}
                    </a>
                ))}
            </div>
        )}
    </article>
</main>