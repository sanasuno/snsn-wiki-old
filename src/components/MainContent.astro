---
/**
 * @components/MainContent.astro
 * メインコンテンツを定義するコンポーネント
 * @param {string} title ページタイトル
 * @param {Locale} locale ロケール
 * @param {string} localeBaseUrl ロケールベースURL
 * @param {string} currentPath 現在のパス
 * @param {string} category カテゴリ
 * @param {string[]} tags タグ
 * @param {Date} date 作成日
 * @param {Date} updated 更新日
 * @param {boolean} isFallbackContent フォールバックコンテンツかどうか
 * @param {boolean} isWikiPage ウィキページかどうか
 * @param {boolean} showMeta メタ情報を表示するかどうか
 */

import { t, locales, translations,type Locale, formatDate } from '@i18n/i18n.config';
import { undefined } from 'astro:schema';
interface Props {
    title: string;
    localeBaseUrl: string;
    locale: Locale;
    currentPath: string;
    categories?: string[];
    tags?: string[];
    date?: Date;
    updated?: Date;
    isFallbackContent?: boolean;
    isWikiPage?: boolean;
    showMeta?: boolean;
}

const { title, localeBaseUrl, locale, currentPath, categories, tags = [], date, updated, isFallbackContent = false, isWikiPage = false, showMeta = true } = Astro.props;
const startyear = 2026;
const year = new Date().getFullYear();

// メタ情報欄に表示するカテゴリ：末尾の1つのみ（例: ['tech', 'astro'] → 'astro'）
const leafCategory = categories && categories.length > 0
    ? { name: categories[categories.length - 1], path: categories.join('/') }
    : null;

type Crumb = {
    label: string;
    href: string;
    categorySegment?: string;
}

/**
 * パンくずリストを構築する
 * @param path パス
 * @param title タイトル
 * @param localeBaseUrl ロケールベースURL
 * @param isWikiPage ウィキページかどうか
 * @returns パンくずリスト
 */
function buildCrumbs(path: string, title: string, localeBaseUrl: string, isWikiPage: boolean): Crumb[] {
    const escapedPrefix = localeBaseUrl.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const normalizedPath = isWikiPage 
        ? path.replace(new RegExp(`^${escapedPrefix}/wiki/`), `${localeBaseUrl}/`)
        : path;
    const strippedPath = normalizedPath.startsWith(localeBaseUrl) 
        ? normalizedPath.slice(localeBaseUrl.length) || '/'
        : normalizedPath;
    const segments = strippedPath.split('/').filter(Boolean);
    const crumbs: Crumb[] = [
        {
            label: t('nav.home', locale),
            href: localeBaseUrl
        }
    ]
    let accumulated = '';
    segments.forEach((segment, index) => {
        accumulated += `/${segment}`;
        const isLast = index === segments.length - 1;
        crumbs.push({
            label: isLast && title ? title : segment,
            href: accumulated,
            categorySegment: !isLast ? segment : '',
        });
    });
    return crumbs;
}

const crumbs: Crumb[] = buildCrumbs(currentPath, title, localeBaseUrl, isWikiPage);
---
<main class="main-content" id="main-content">
    {isFallbackContent && (
        <div class="fallback-warning">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>{t('fallback.warning', locale)}</span>
        </div>
    )}
    {showMeta && (
        <header class="page-header">
            <!-- パンくずリスト -->
            <nav class="breadcrumb">
                <ol class="breadcrumbs">
                    {crumbs.map((crumb, index) => {
                        const isHome = index === 0;
                        const isLast = index === crumbs.length - 1;
                        return (
                            <>
                                <li class:list={[{ 'breadcrumb__current': isLast }]} aria-current={isLast ? 'page' : undefined}>
                                    {crumb.href &&
                                        isHome
                                            ? isLast
                                                ? <>
                                                    <i class="fa-solid fa-house" />
                                                    <span>{crumb.label}</span>
                                                </>
                                                : <>
                                                    <i class="fa-solid fa-house" />
                                                    <a href={crumb.href}>{crumb.label}</a>
                                                </>
                                            : isLast
                                                ? <>
                                                    <i class="fa-regular fa-file" />
                                                    <span>{crumb.label}</span>
                                                </>
                                                : <>
                                                    <!-- カテゴリページへのリンク -->
                                                    <i class="fa-solid fa-folder" />
                                                    <a href={`${localeBaseUrl}/category${crumb.href}`}>
                                                        {t(`category.${crumb.label}`, locale) !== `category.${crumb.label}` 
                                                            ? t(`category.${crumb.label}`, locale) 
                                                            : crumb.label}
                                                    </a>
                                                </>
                                    }
                                </li>
                                {!isLast && (
                                    <li class="breadcrumb__separator" aria-hidden="true">
                                        <i class="fa-solid fa-chevron-right" />
                                    </li>
                                )}
                            </>
                        );
                    })}
                </ol>
            </nav>
            <!-- タイトル -->
            <h1 class="page-title">{title}</h1>
            <!-- メタ情報 -->
            <div class="page-meta">
                {leafCategory && (
                    <div class="page-category">
                        <a href={`${localeBaseUrl}/category/${leafCategory.path}`}>
                            <i class="fa-regular fa-folder" />
                            {translations[leafCategory.name as Locale] ? t(`category.${leafCategory.name}`, locale) : leafCategory.name}
                        </a>
                    </div>
                )}
                {(date || updated) && (
                    <div class="page-meta-dates">
                        {date && (
                            <span class="page-date">
                                <i class="fa-regular fa-calendar-plus" />
                                {t("meta.created", locale)}: {formatDate(date, locale)}
                            </span>
                        )}
                        {updated && (
                            <span class="page-date">
                                <i class="fa-solid fa-clock-rotate-left" />
                                {t("meta.updated", locale)}: {formatDate(updated, locale)}
                            </span>
                        )}
                    </div>
                )}
            </div>
        </header>
    )}
    <article class="article-content">
        <slot />
        <!-- タグ -->
        {tags.length > 0 && (
            <div class="page-tags">
                {tags.map(tag => (
                    <a href={`${localeBaseUrl}/tag/${encodeURIComponent(tag)}`} class="tag">
                        #{tag}
                    </a>
                ))}
            </div>
        )}
    </article>
    <!-- フッター -->
    <footer class="site-footer">
        <div class="site-footer-links">
            <a href={`${localeBaseUrl}/privacy`}>{t('footer.privacy', locale)}</a>
            <a href={`${localeBaseUrl}/terms`}>{t('footer.terms', locale)}</a>
        </div>
        <div class="site-footer-credit">
            © {startyear}-{year} {t('site.title', locale)}.
        </div>
    </footer>
</main>