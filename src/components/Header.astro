---
/**
 * @components/Header.astro
 * サイト全体のヘッダーを定義するコンポーネント
 * @param {Locale} locale - ロケール
 * @param {string} localeBaseUrl - ロケールベースURL
 * @param {string} currentPath - 現在のパス
 */

import { t, locales, type Locale, showLanguageSwitcher } from "@i18n/i18n.config";
import { headerNavigation } from "@layouts/header.config";

interface Props {
    locale: Locale;
    localeBaseUrl: string;
    currentPath: string;
}

const { localeBaseUrl, locale, currentPath }: Props = Astro.props;

const navItems= headerNavigation;

// 現在のURLに基づいてナビゲーションのアクティブ状態を判定する関数
// normalize()による正規化が前提
function isActive(targetPath: string, currentPath: string, localeBaseUrl: string): boolean {
    const targetUrl = `${localeBaseUrl}${targetPath}`;
    // ルートパスの場合、自身のパスと一致する場合にアクティブ
    if (targetPath === '/') {
        return currentPath === localeBaseUrl;
    }
    // 他のパスの場合、対象URL自身またはそのサブパスである場合にアクティブ
    return (
        currentPath === targetUrl || 
        currentPath.startsWith(`${targetUrl}/`)
    );
}
---

<header class="site-header">
    <!-- モバイルサイドバーのトグルボタン -->
    <button class="sidebar-toggle" id="sidebar-toggle" aria-label={t('sidebar.toggle', locale)}>
        <i class="fa-solid fa-bars"></i>
    </button>

    <!-- サイトタイトル -->
    <a href={localeBaseUrl} class="site-title">{t("site.title", locale)}</a>

    <!-- ナビゲーション -->
    <nav class="header-nav" aria-label={t("header.navigation", locale)}>
        {
            navItems.map((item) => (
                <a href={localeBaseUrl + item.path} class:list={[{ active: isActive(item.path, currentPath, localeBaseUrl) }]}>
                    <i class={item.icon}></i>
                    <span class="nav-label" data-i18n={item.i18nKey}>
                        {t(item.i18nKey, locale)}
                    </span>
                </a>
            ))
        }

        <!-- ダーク / ライトモード切替ボタン -->
        <button class="theme-toggle" id="theme-toggle" aria-label={t("theme.toggle", locale)}>
            <i class="fa-solid fa-moon icon-dark"></i>
            <i class="fa-solid fa-sun icon-light"></i>
        </button>

        <!-- 言語切替ボタン -->
        { showLanguageSwitcher && (
            <div class="language-switcher" title={t('lang.label', locale)}>
                <i class="fa-solid fa-language lang-menu-icon" aria-hidden="true" />
                <select id="lang-list" class="lang-list" aria-label={t('lang.list', locale)}>
                    {
                        locales.map((lang: Locale) => ( 
                                <option value={lang} selected={lang === locale}>
                                    {t(`lang.${lang}`, lang)}
                                </option>
                        ))
                    }
                </select>
                <i class="fa-solid fa-chevron-down lang-menu-caret" aria-hidden="true" />
            </div>
        )}
    </nav>
</header>