---
/**
 * @components/GraphView.astro
 * グラフビューコンポーネント
 */

import { t, type Locale } from "@i18n/i18n.config";
interface Props {
    locale: Locale;
    localeBaseUrl: string;
}

const { locale, localeBaseUrl }: Props = Astro.props;
---
<div class="graph-container" id="graph-container"
    data-locale={locale}
    data-locale-base-url={localeBaseUrl}
    data-err-fetch={t('graph.error.fetch', locale)}
    data-err-no-nodes={t('graph.error.noNodes', locale)}>
    <canvas class="graph-canvas" id="graph-canvas" />

    <!-- ツールチップ -->
    <div class="graph-tooltip" id="graph-tooltip">
        <div class="graph-tooltip-title" id="graph-tooltip-title" />
        <div class="graph-tooltip-tags" id="graph-tooltip-tags" />
    </div>

    <!-- コントロール -->
     <div class="graph-controls">
        <button class="graph-button" id="zoom-in" title={t('graph.zoomIn', locale)}>
            <i class="fa-solid fa-plus" />
        </button>
        <button class="graph-button" id="zoom-out" title={t('graph.zoomOut', locale)}>
            <i class="fa-solid fa-minus" />
        </button>
        <button class="graph-button" id="zoom-fit" title={t('graph.zoomFit', locale)}>
            <i class="fa-solid fa-expand" />
        </button>
        <button class="graph-button" id="toggle-color" title={t('graph.toggleColor', locale)} style="margin-top: 8px;">
            <i class="fa-solid fa-palette" />
        </button>
     </div>

     <!-- ローディング表示 -->
     <div class="graph-loading" id="graph-loading">
        <div class="graph-loading-spinner">
            <i class="fa-solid fa-spinner fa-spin" />
            {t('graph.loading', locale)}
        </div>
     </div>

     <!-- 凡例 -->
     <div class="graph-legend" id="graph-legend">
        <div>
            <span class="legend-node-sample" id="legend-node-sample" />
            {t('graph.legendPage', locale)}
        </div>
        <div>
            <span class="legend-current" id="legend-current" />
            {t('graph.legendCurrent', locale)}
        </div>
        <div>
            <span class="legend-missing" id="legend-missing" />
            {t('graph.legendMissing', locale)}
        </div>
    </div>
</div>

<style>
    /* -------- グラフページ -------- */
    .graph-container {
        width: 100%;
        height: calc(100vh - var(--header-height) - 80px);
        min-height: 400px;
        position: relative;
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .graph-canvas {
        display: block;
        position: absolute;
        inset: 0;
    }

    .graph-tooltip {
        position: absolute;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 8px 12px;
        font-size: 0.8rem;
        pointer-events: none;
        box-shadow: var(--shadow-lg);
        opacity: 0;
        transition: opacity 0.15s;
        max-width: 200px;
        z-index: 10;
    }

    .graph-tooltip.visible {
        opacity: 1;
    }

    .graph-tooltip-title {
        font-weight: 600;
        margin-bottom: 4px;
    }

    .graph-tooltip-tags {
        color: var(--color-text-muted);
        font-size: 0.75rem;
    }

    .graph-controls {
        position: absolute;
        top: 12px;
        right: 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .graph-button {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        cursor: pointer;
        color: var(--color-text-muted);
        font-size: 1rem;
        transition: all var(--transition);
    }

    .graph-button:hover {
        background: var(--color-bg-secondary);
        color: var(--color-text);
    }

    .graph-loading {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-muted);
        font-size: 0.875rem;
        pointer-events: none;
    }

    .graph-loading i {
        margin-right: 8px;
    }

    .graph-legend {
        position: absolute;
        bottom: 12px;
        left: 12px;
        display: flex;
        flex-direction: column;
        gap: 5px;
        font-size: 0.72rem;
        color: var(--color-text-muted);
    }

    .graph-legend div {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .legend-node-sample {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #6366f1;
    }

    .legend-current {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #f59e0b;
    }

    .legend-missing {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #e5e7eb;
        border: 1.5px dashed #9ca3af;
    }
</style>

<script>
  import "@scripts/graph/graphpage"
</script>