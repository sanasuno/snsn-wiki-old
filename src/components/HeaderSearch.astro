---
/**
 * src/components/HeaderSearch.astro
 *
 * ヘッダー用検索コンポーネント。
 * - 入力中: ドロップダウンで候補を最大8件表示
 * - Enter / 候補クリック: /[locale]/search?q=... に遷移
 * - Esc: ドロップダウンを閉じる
 */
import type { Locale } from '@i18n/i18n.config';
import { t, defaultLocale } from '@i18n/i18n.config';
import { removeTrailingSlash } from '@lib/path';

interface Props {
    locale?: Locale;
    localeBaseUrl?: string;
}

const { locale = defaultLocale, localeBaseUrl = '' } = Astro.props;

const baseUrl = removeTrailingSlash(import.meta.env.BASE_URL); // ベースURL
const placeholder = t('search.placeholder', locale); // 検索ボックスのプレースホルダー
const searchPageUrl = `${localeBaseUrl}/search`; // 検索ページのURL
---

<div
    id="header-search-root"
    class="header-search"
    data-locale={locale}
    data-base-url={baseUrl}
    data-search-page={searchPageUrl}
    role="search"
>
    <!-- 検索アイコン -->
    <i class="fa-solid fa-magnifying-glass header-search-icon" aria-hidden="true" />

    <!-- 検索入力ボックス -->
    <input
        id="header-search-input"
        class="header-search-input"
        type="search"
        placeholder={placeholder}
        autocomplete="off"
        spellcheck="false"
        aria-label={placeholder}
        aria-autocomplete="list"
        aria-controls="header-search-dropdown"
        aria-expanded="false"
    />

    <!-- ドロップダウン -->
    <ul
        id="header-search-dropdown"
        class="header-search-dropdown"
        role="listbox"
        hidden
    ></ul>
</div>

<style is:global>
.header-search {
    position: relative;
    display: flex;
    align-items: center;
    flex: 1;
    max-width: 280px;
    min-width: 0;
}

.header-search-icon {
    position: absolute;
    left: 10px;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    pointer-events: none;
    z-index: 1;
}

.header-search-input {
    width: 100%;
    padding: 6px 10px 6px 30px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    font-size: 0.875rem;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
}

.header-search-input:focus {
    border-color: var(--color-accent);
    background: var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-accent-light, rgba(99,102,241,0.12));
}

.header-search-input::-webkit-search-cancel-button {
    display: none;
}

/* ドロップダウン */
.header-search-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-lg);
    list-style: none;
    margin: 0;
    padding: 4px;
    z-index: 9999;
    max-height: 320px;
    overflow-y: auto;
    scrollbar-width: thin;
}

.header-search-dropdown[hidden] {
    display: none;
}

/* 各候補 */
.hsd-item {
    border-radius: var(--radius-sm);
}

.hsd-item a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 10px;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-sm);
    outline: none;
    transition: background var(--transition);
}

.hsd-item a:hover,
.hsd-item.active a {
    background: var(--color-bg-accent);
}

.hsd-item-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.hsd-item-title i {
    color: var(--color-text-subtle);
    font-size: 0.7rem;
    flex-shrink: 0;
}

.hsd-item-title mark {
    background: var(--color-accent-light, rgba(99,102,241,0.15));
    color: var(--color-accent);
    border-radius: 2px;
    padding: 0 2px;
    font-weight: 700;
}

.hsd-item-excerpt {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.hsd-item-excerpt mark {
    background: var(--color-accent-light, rgba(99,102,241,0.15));
    color: var(--color-accent);
    border-radius: 2px;
    padding: 0 2px;
    font-weight: 600;
}

/* 「すべての結果を見る」フッター */
.hsd-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4px;
    padding-top: 4px;
}

.hsd-footer a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 10px;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background var(--transition), color var(--transition);
}

.hsd-footer a:hover,
.hsd-footer.active a {
    background: var(--color-bg-accent);
    color: var(--color-accent);
}

/* ローディング / 結果なし */
.hsd-status {
    padding: 10px;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-muted);
}
</style>

<script>
import { highlight, extractSnippet, search } from '@scripts/search';
import { t, defaultLocale, type Locale } from '@i18n/i18n.config';
import type { SearchEntry } from '@scripts/search';

const root       = document.getElementById('header-search-root')!; // ルート要素
const input      = document.getElementById('header-search-input') as HTMLInputElement; // 検索入力ボックス
const dropdown   = document.getElementById('header-search-dropdown') as HTMLUListElement; // ドロップダウン

const locale     = (root.dataset.locale     ?? defaultLocale) as Locale; // ロケール
const baseUrl    = root.dataset.baseUrl    ?? ''; // ベースURL
const searchPage = root.dataset.searchPage ?? ''; // 検索ページURL

const DEBOUNCE_MS   = 120; // デバウンス時間
const MAX_DROPDOWN  = 8; // 表示する最大候補数
const CONTEXT_CHARS = 40; // コンテキスト文字数

let index: SearchEntry[] | null = null; // 検索インデックス
let debounceTimer: ReturnType<typeof setTimeout> | null = null; // デバウンスタイマー
let activeIdx = -1; // アクティブな候補のインデックス、-1 = なし、0 = 「すべての結果を見る」、1~ = 候補

// ---- インデックスロード ----
/**
 * インデックスを確保する
 * @returns {Promise<void>} ロード完了まで待機
 */
async function ensureIndex() {
    // 既にロード済みなら何もしない
    if (index) return;
    try {
        // インデックスを取得
        const res = await fetch(`${baseUrl}/search-index.${locale}.json`);
        // HTTPエラーの場合はエラーをスローする
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        // JSONとしてパースする
        index = await res.json();
    } catch (e) {
        // エラーをログに出力する
        console.error('[HeaderSearch] index load failed:', e);
    }
}

// ---- ドロップダウン表示 ----
/**
 * ドロップダウンを表示する
 */
function openDropdown() {
    dropdown.hidden = false;
    input.setAttribute('aria-expanded', 'true');
}

/**
 * ドロップダウンを非表示にする
 */
function closeDropdown() {
    dropdown.hidden = true;
    input.setAttribute('aria-expanded', 'false');
    activeIdx = -1;
}

/**
 * ドロップダウンをレンダリングする
 * @param entries 検索結果
 * @param query 検索クエリ
 */
function renderDropdown(entries: SearchEntry[], query: string) {
    dropdown.innerHTML = ''; // ドロップダウンをクリア
    activeIdx = -1; // アクティブな候補をリセット

    if (!entries.length) {
        // 結果がなかった場合、ステータスを表示してドロップダウンを開く
        dropdown.innerHTML = `
            <li class="hsd-status">
                ${t('search.noResults', locale)}
            </li>
        `;
        openDropdown();
        return;
    }

    // 候補リストをレンダリングする
    for (const entry of entries) {
        // スニペットを抽出する
        const snippet = extractSnippet(entry.body, query.trim(), CONTEXT_CHARS);
        // リストを作成する
        const li = document.createElement('li');
        li.className = 'hsd-item';
        li.setAttribute('role', 'option');
        // リンクを作成する
        const a = document.createElement('a');
        a.href = `${baseUrl}${entry.url}`;
        a.innerHTML = `
            <span class="hsd-item-title">
                <i class="fa-regular fa-file-lines"></i>
                ${highlight(entry.title, query.trim())}
            </span>
            <span class="hsd-item-excerpt">
                ${highlight(snippet, query.trim())}
            </span>
        `;
        a.addEventListener('mousedown', (e) => {
            // マウスダウン時に遷移させる
            e.preventDefault();
            closeDropdown();
            window.location.href = a.href;
        });
        li.appendChild(a);
        dropdown.appendChild(li);
    }

    // 「すべての結果を見る」フッター
    const footer = document.createElement('li');
    footer.className = 'hsd-footer';
    footer.setAttribute('role', 'option');
    // リンクを作成する
    const footerA = document.createElement('a');
    footerA.href = `${searchPage}?q=${encodeURIComponent(query.trim())}`;
    const allLabel = t('search.seeAllResults', locale);
    footerA.innerHTML = `
        <span>${allLabel}</span>
        <i class="fa-solid fa-arrow-right" />
    `;
    footerA.addEventListener('mousedown', (e) => {
        // マウスダウン時に遷移させる
        e.preventDefault();
        closeDropdown();
        window.location.href = footerA.href;
    });
    // フッターにリンクを追加し、ドロップダウンにフッターを追加する
    footer.appendChild(footerA);
    dropdown.appendChild(footer);
    // ドロップダウンを開く
    openDropdown();
}

// ---- キーボードナビ ----
/**
 * ドロップダウン内のアイテムを取得する
 * @returns ドロップダウン内のアイテム
 */
function getItems(): HTMLElement[] {
    // hsd-item の a + hsd-footer の a
    return Array.from(dropdown.querySelectorAll('.hsd-item, .hsd-footer')) as HTMLElement[];
}

/**
 * アクティブなアイテムを設定する
 * @param idx アクティブなアイテムのインデックス
 */
function setActive(idx: number) {
    // ドロップダウン内のアイテムを取得する
    const items = getItems();
    // アクティブなアイテムを設定する
    items.forEach((el, i) => el.classList.toggle('active', i === idx));
    // アクティブなアイテムをスクロールする
    if (items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
    activeIdx = idx;
}

/**
 * アクティブなアイテムを移動する
 * @param dir 移動方向（-1: 上, 1: 下）
 */
function moveActive(dir: number) {
    // ドロップダウン内のアイテムを取得する
    const items = getItems();
    // アイテムがない場合は終了
    if (!items.length) return;
    
    // アクティブなアイテムを移動する
    let next = activeIdx + dir;
    if (next < -1) next = items.length - 1; // 最後へ
    if (next >= items.length) next = -1; // 最初へ
    if (next === -1) {
        // -1 のときは選択解除（input にフォーカス戻る）
        items.forEach(el => el.classList.remove('active'));
        activeIdx = -1;
    } else {
        // アクティブなアイテムを設定する
        setActive(next);
    }
}

/**
 * 選択されたアイテムをアクティブにする
 */
function activateSelected() {
    const items = getItems();
    const item = items[activeIdx];
    if (item) {
        // アクティブなアイテムのリンクを取得し、遷移する
        const a = item.querySelector('a') as HTMLAnchorElement | null;
        if (a) { closeDropdown(); window.location.href = a.href; }
    } else {
        // 何も選択されていない場合は検索ページへ
        goToSearchPage();
    }
}

/**
 * 検索ページへ遷移する
 */
function goToSearchPage() {
    const q = input.value.trim();
    if (!q) return;
    closeDropdown();
    window.location.href = `${searchPage}?q=${encodeURIComponent(q)}`;
}

// ---- イベント ----
// フォーカス時イベント
input.addEventListener('focus', async () => {
    if (input.value.trim()) {
        // インデックスがなければ読み込んでから検索
        await ensureIndex();
        const hits = search(input.value, index!, MAX_DROPDOWN);
        renderDropdown(hits, input.value);
    }
});

// 入力時イベント
input.addEventListener('input', () => {
    const q = input.value;
    if (debounceTimer) clearTimeout(debounceTimer); // 既存のタイマーをクリア
    if (!q.trim()) {closeDropdown(); return; } // 入力がない場合はドロップダウンを閉じる

    debounceTimer = setTimeout(async () => {
        // インデックスがなければ読み込んでから検索
        await ensureIndex();
        const hits = search(q, index!, MAX_DROPDOWN);
        renderDropdown(hits, q);
    }, DEBOUNCE_MS);
});

// キーボード操作イベント
input.addEventListener('keydown', (e) => {
    if (dropdown.hidden) {
        // ドロップダウンが表示されていない場合、Enterキーで検索ページへ遷移
        if (e.key === 'Enter') { e.preventDefault(); goToSearchPage(); }
        return;
    }
    if (e.key === 'ArrowDown')  { e.preventDefault(); moveActive(+1); } // 下キーが押された場合、次のアイテムを選択
    if (e.key === 'ArrowUp')    { e.preventDefault(); moveActive(-1); } // 上キーが押された場合、前のアイテムを選択
    if (e.key === 'Enter')      { e.preventDefault(); activateSelected(); } // Enterキーが押された場合、選択されたアイテムをアクティブにする
    if (e.key === 'Escape')     { e.preventDefault(); closeDropdown(); } // Escapeキーが押された場合、ドロップダウンを閉じる
});

// フォーカスが外れたらドロップダウンを閉じる
input.addEventListener('blur', () => {
    // mousedown で先に遷移しているので少し遅らせる
    setTimeout(closeDropdown, 150);
});

// ページ外クリックで閉じる
document.addEventListener('click', (e) => {
    if (!root.contains(e.target as Node)) closeDropdown();
});

// / キー or Ctrl+K でヘッダー入力欄にフォーカス
document.addEventListener('keydown', (e) => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        // Ctrl+K が押された場合、ヘッダー入力欄にフォーカスを当てる
        e.preventDefault(); input.focus();
    }
    if (e.key === '/' && tag !== 'INPUT' && tag !== 'TEXTAREA') {
        // / キーが押された場合、ヘッダー入力欄にフォーカスを当てる
        e.preventDefault(); input.focus();
    }
});
</script>