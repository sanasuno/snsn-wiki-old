---
/**
 * @components/MiniGraph
 * ミニグラフコンポーネント
 * 
 * @param props - コンポーネントプロパティ
 * @param props.currentPath - 現在のパス
 * @param props.locale - ロケール
 * @param props.localeBaseUrl - ロケールに基づいたベースURL
 */
import {t, type Locale} from '@i18n/i18n.config';
interface Props {
  currentPath: string;
  locale: Locale;
  localeBaseUrl: string;
}

const { currentPath, locale, localeBaseUrl } = Astro.props;
---
<section class="mini-graph-section">
  <div class="mini-graph-header">
    <span class="mini-graph-title">
      <i class="fa-solid fa-diagram-project" />
      {t('graph.mini.title', locale)}
    </span>
    <a href={`${localeBaseUrl}/graph`} class="mini-graph-link" title={t('graph.openFull', locale)}>
      <i class="fa-solid fa-arrow-up-right-from-square" />
    </a>
  </div>
  <div class="mini-graph-container" id="mini-graph-container"  data-current-path={currentPath} data-locale={locale} data-locale-base-url={localeBaseUrl} data-no-link-msg={t('graph.mini.noLinks', locale)}>
    <canvas id="mini-graph-canvas" role="img" aria-label={t('graph.mini.title', locale)} />
    <div id="mini-graph-loading">
      <i class="fa-solid fa-spinner fa-spin" />
      {t('graph.loading', locale)}
    </div>
  </div>
</section>

<script>
  import "@scripts/minigraph"
</script>