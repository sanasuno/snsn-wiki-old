---
/**
 * src/components/SearchModal.astro
 *
 * 全文検索モーダル。
 * - ビルド時生成の /search-index.[locale].json をクライアントサイドで fetch
 * - タイトル＋本文をリアルタイムフィルタリング（デバウンス 150ms）
 * - キーボード操作対応（/, Ctrl+K でモーダルを開く / Esc で閉じる / ↑↓ で移動）
 */
import type { Locale } from '@i18n/i18n.config';
import { t, defaultLocale } from '@i18n/i18n.config';

interface Props {
    locale?: Locale;
    baseUrl?: string;
}

const { locale = defaultLocale, baseUrl = '' } = Astro.props;

// i18n ラベル
const label = {
    placeholder: t('search.placeholder', locale),
    noResults:   t('search.noResults',   locale),
    loading:     t('search.loading',     locale),
    title:       t('search.title',       locale),
    hint:        t('search.hint',        locale),
};
---

<!-- トリガーボタン（Header から呼び出す） -->
<button
    id="search-trigger"
    class="search-trigger"
    aria-label={label.title}
    title={`${label.title} (/)`}
>
    <i class="fa-solid fa-magnifying-glass"></i>
    <span class="search-trigger-label">
        {label.title}
    </span>
    <kbd class="search-trigger-kbd">/</kbd>
</button>

<!-- モーダルオーバーレイ -->
<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label={label.title} hidden>
    <div class="search-modal-backdrop"></div>
    <div class="search-modal-panel">
        <!-- 検索入力 -->
        <div class="search-input-wrapper">
            <i class="fa-solid fa-magnifying-glass search-input-icon"></i>
            <input
                id="search-input"
                class="search-input"
                type="search"
                placeholder={label.placeholder}
                autocomplete="off"
                spellcheck="false"
            />
            <kbd class="search-esc-kbd">Esc</kbd>
        </div>

        <!-- 結果リスト -->
        <ul id="search-results" class="search-results" role="listbox"></ul>

        <!-- 状態メッセージ（ローディング・結果なし） -->
        <p id="search-status" class="search-status" aria-live="polite" hidden></p>

        <!-- フッターヒント -->
        <div class="search-footer">
            <span><kbd>↑</kbd><kbd>↓</kbd> {label.hint}</span>
        </div>
    </div>
</div>

<style>
/* -------- トリガーボタン -------- */
.search-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: none;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition), color var(--transition);
    white-space: nowrap;
}

.search-trigger:hover {
    background-color: var(--color-bg-hover);
    border-color: var(--color-border-hover);
    color: var(--color-text);
}

.search-trigger-label {
    /* 小さい画面では非表示 */
}

.search-trigger-kbd {
    font-size: 0.7rem;
    padding: 1px 5px;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    background: var(--color-bg-secondary);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    line-height: 1.5;
}

@media (max-width: 900px) {
    .search-trigger-label,
    .search-trigger-kbd {
        display: none;
    }
}

/* -------- モーダル -------- */
.search-modal {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: clamp(60px, 10vh, 120px);
}

.search-modal[hidden] {
    display: none;
}

.search-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(2px);
}

.search-modal-panel {
    position: relative;
    width: min(640px, calc(100vw - 32px));
    max-height: calc(100vh - 140px);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 12px);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

/* -------- 入力欄 -------- */
.search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
}

.search-input-icon {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    flex-shrink: 0;
}

.search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 1rem;
    color: var(--color-text);
    font-family: var(--font-sans);
}

.search-input::placeholder {
    color: var(--color-text-subtle);
}

/* Chrome の ✕ ボタンを隠す */
.search-input::-webkit-search-cancel-button {
    display: none;
}

.search-esc-kbd {
    font-size: 0.7rem;
    padding: 2px 6px;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    background: var(--color-bg-secondary);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    flex-shrink: 0;
    cursor: pointer;
}

/* -------- 結果リスト -------- */
.search-results {
    list-style: none;
    margin: 0;
    padding: 6px;
    overflow-y: auto;
    flex: 1;
    scrollbar-width: thin;
}

.search-result-item {
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background var(--transition);
}

.search-result-link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 10px 12px;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-sm);
    outline: none;
}

.search-result-item:hover .search-result-link,
.search-result-item.active .search-result-link {
    background: var(--color-bg-accent);
}

.search-result-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 6px;
}

.search-result-title i {
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    flex-shrink: 0;
}

.search-result-title mark {
    background: var(--color-accent-light, rgba(99,102,241,0.15));
    color: var(--color-accent);
    border-radius: 2px;
    padding: 0 2px;
    font-weight: 700;
}

.search-result-excerpt {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    /* 最大2行 */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.search-result-excerpt mark {
    background: var(--color-accent-light, rgba(99,102,241,0.15));
    color: var(--color-accent);
    border-radius: 2px;
    padding: 0 2px;
    font-weight: 600;
}

.search-result-url {
    font-size: 0.7rem;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
}

/* -------- ステータス -------- */
.search-status {
    text-align: center;
    padding: 24px 16px;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    flex-shrink: 0;
}

/* -------- フッター -------- */
.search-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 8px 14px;
    border-top: 1px solid var(--color-border);
    font-size: 0.72rem;
    color: var(--color-text-subtle);
    flex-shrink: 0;
    gap: 4px;
}

.search-footer kbd {
    font-size: 0.65rem;
    padding: 1px 4px;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    background: var(--color-bg-secondary);
    font-family: var(--font-mono);
    line-height: 1.4;
}
</style>

<script define:vars={{ locale, baseUrl }}>
import { highlight, extractSnippet, search } from "@scripts/search";

// ----------------------------------------
// 検索ロジック（クライアントサイド）
// ----------------------------------------

const DEBOUNCE_MS = 150;
const MAX_RESULTS = 20;
/** スニペット前後に表示するコンテキスト文字数 */
const CONTEXT_CHARS = 60;

let index = null;       // SearchEntry[]
let activeIdx = -1;     // キーボードナビ用
let debounceTimer = null;

const modal    = document.getElementById('search-modal');
const input    = document.getElementById('search-input');
const results  = document.getElementById('search-results');
const status   = document.getElementById('search-status');
const trigger  = document.getElementById('search-trigger');
const backdrop = modal?.querySelector('.search-modal-backdrop');
const escKbd   = modal?.querySelector('.search-esc-kbd');

// ----------------------------------------
// モーダル開閉
// ----------------------------------------

async function openModal() {
    if (!modal) return;
    modal.removeAttribute('hidden');
    input?.focus();
    if (!index) await loadIndex();
}

function closeModal() {
    if (!modal) return;
    modal.setAttribute('hidden', '');
    input.value = '';
    clearResults();
    activeIdx = -1;
}

function clearResults() {
    results.innerHTML = '';
    status.hidden = true;
}

// ----------------------------------------
// インデックスの遅延ロード
// ----------------------------------------

async function loadIndex() {
    showStatus('loading');
    try {
        const url = `${baseUrl}/search-index.${locale}.json`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        index = await res.json();
        showStatus(null);
    } catch (e) {
        console.error('[Search] Failed to load index:', e);
        showStatus('error');
    }
}

function showStatus(type) {
    if (!status) return;
    if (!type) { status.hidden = true; return; }
    status.hidden = false;
    const msgs = {
        loading: locale === 'ja' ? '読み込み中…' : 'Loading…',
        error:   locale === 'ja' ? 'インデックスの読み込みに失敗しました' : 'Failed to load search index',
        empty:   locale === 'ja' ? '結果が見つかりませんでした' : 'No results found',
    };
    status.textContent = msgs[type] ?? '';
}


// ----------------------------------------
// 結果の描画
// ----------------------------------------

function renderResults(entries, query) {
    results.innerHTML = '';
    activeIdx = -1;

    if (!entries.length) {
        if (query.trim()) showStatus('empty');
        return;
    }
    showStatus(null);

    for (const entry of entries) {
        const snippet  = extractSnippet(entry.body, query.trim());
        const li = document.createElement('li');
        li.className = 'search-result-item';
        li.setAttribute('role', 'option');

        const a = document.createElement('a');
        a.className = 'search-result-link';
        a.href = `${baseUrl}${entry.url}`;

        a.innerHTML = `
            <span class="search-result-title">
                <i class="fa-regular fa-file-lines"></i>
                ${highlight(entry.title, query.trim())}
            </span>
            <span class="search-result-excerpt">${highlight(snippet, query.trim())}</span>
        `;

        a.addEventListener('click', () => closeModal());
        li.appendChild(a);
        results.appendChild(li);
    }
}

// ----------------------------------------
// キーボードナビゲーション
// ----------------------------------------

function getItems() {
    return Array.from(results.querySelectorAll('.search-result-item'));
}

function setActive(idx) {
    const items = getItems();
    items.forEach((el, i) => el.classList.toggle('active', i === idx));
    if (items[idx]) {
        items[idx].scrollIntoView({ block: 'nearest' });
    }
    activeIdx = idx;
}

function moveActive(dir) {
    const items = getItems();
    if (!items.length) return;
    let next = activeIdx + dir;
    if (next < 0) next = items.length - 1;
    if (next >= items.length) next = 0;
    setActive(next);
}

function openActive() {
    const items = getItems();
    const item = items[activeIdx];
    if (item) {
        const a = item.querySelector('a');
        if (a) { a.click(); }
    }
}

// ----------------------------------------
// イベント登録
// ----------------------------------------

trigger?.addEventListener('click', openModal);
backdrop?.addEventListener('click', closeModal);
escKbd?.addEventListener('click', closeModal);

input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
        const q = input.value;
        if (!q.trim()) { clearResults(); return; }
        const hits = search(q, index);
        renderResults(hits, q);
    }, DEBOUNCE_MS);
});

input?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown')  { e.preventDefault(); moveActive(+1); }
    if (e.key === 'ArrowUp')    { e.preventDefault(); moveActive(-1); }
    if (e.key === 'Enter')      { e.preventDefault(); openActive(); }
    if (e.key === 'Escape')     { closeModal(); }
});

document.addEventListener('keydown', (e) => {
    if (modal?.hasAttribute('hidden')) {
        // モーダルが閉じているとき: / か Ctrl+K で開く
        if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
            e.preventDefault();
            openModal();
        }
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            openModal();
        }
    } else {
        // モーダルが開いているとき: Esc で閉じる
        if (e.key === 'Escape') closeModal();
    }
});
</script>