---
/**
 * @components/MermaidRenderer.astro
 * Mermaid図をレンダリングするコンポーネント
 */
---
<script>
    import mermaid from 'mermaid'

    /**
     * テーマを取得する関数
     * @returns {string} テーマ名
     */
    function getTheme() {
        const t = document.documentElement.getAttribute('data-theme');
        if (t === 'dark') return 'dark';
        if (t === 'light') return 'default';
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'default';
    }

    /**
     * コードブロックからソースを抽出する関数
     * @param {Element} pre - コードブロック要素
     * @returns {string} コードソース
     */
    function extractSource(pre: Element) {
        const lines = pre.querySelectorAll('.line');
        // .line要素が存在する場合、それらのテキストコンテンツを結合する
        if (lines.length > 0) {
            return Array.from(lines).map(l => l.textContent).join('\n');
        }
        return (pre.querySelector('code') as HTMLElement)?.textContent ?? pre.textContent ?? '';
    }

    let counter = 0;

    /**
     * Mermaid図をレンダリングする関数
     * @param selector - 対象の要素セレクタ
     * @param getSource - 要素からソースを取得する関数
     * @param replaceKind - 置換する要素の種類
     */
    async function renderMermaidBlocks(selector: string, getSource: (el: Element) => string, replaceKind: 'pre' | 'div') {
        mermaid.initialize({
            startOnLoad: false,
            theme: getTheme(),
            securityLevel: 'loose'
        });

        const blocks = document.querySelectorAll(selector);
        for (const el of blocks) {
            const source = getSource(el);
            if (!source) continue;
            const id = `mermaid-${counter++}`;
            try {
                const { svg } = await mermaid.render(id, source);
                const wrapper = document.createElement('div');
                wrapper.className = 'mermaid';
                wrapper.dataset.mermaidSource = source;
                wrapper.innerHTML = svg;
                el.parentNode?.replaceChild(wrapper, el);
            } catch(error) {
                if (replaceKind === 'pre') {
                    const msg = document.createElement('pre');
                    msg.className = 'mermaid-error';
                    msg.textContent = `Mermaid rendering failed: ${(error as Error).message}`;
                    el.parentNode?.replaceChild(msg, el);
                }
                console.error('Mermaid render error:', error);
            }
        }
    }

    renderMermaidBlocks('pre[data-language="mermaid"]', extractSource, 'pre');

    document.getElementById('theme-toggle')?.addEventListener('click', () => {
        setTimeout(() => {
            renderMermaidBlocks('.mermaid', (el) => (el as HTMLElement).dataset.mermaidSource ?? '', 'div');
        })
    })
</script>