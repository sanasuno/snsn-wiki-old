---
/**
 * @components/MermaidRenderer.astro
 * Mermaid図をレンダリングするコンポーネント
 */
---
<script>
    import mermaid from 'mermaid'

    /**
     * テーマを取得する関数
     * @returns {string} テーマ名
     */
    function getTheme() {
        const t = document.documentElement.getAttribute('data-theme');
        if (t === 'dark') return 'dark';
        if (t === 'light') return 'default';
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'default';
    }

    /**
     * コードブロックからソースを抽出する関数
     * @param {HTMLElement} pre - コードブロック要素
     * @returns {string} コードソース
     */
    function extractSource(pre: HTMLElement) {
        const lines = pre.querySelectorAll('.line');
        // .line要素が存在する場合、それらのテキストコンテンツを結合する
        if (lines.length > 0) {
            return Array.from(lines).map(l => l.textContent).join('\n');
        }
        return (pre.querySelector('code') as HTMLElement)?.textContent ?? pre.textContent ?? '';
    }

    let counter = 0;

    /**
     * すべてのMermaid図をレンダリングする関数
     */
    async function renderAll() {
        mermaid.initialize({
            startOnLoad: false,
            theme: getTheme(),
            securityLevel: 'loose'
        });

        const blocks = document.querySelectorAll('pre[data-lang="mermaid"]');
        for (const pre of blocks) {
            const source = extractSource(pre as HTMLElement);
            const id = `mermaid-${counter++}`;
            try {
                // Mermaid図をレンダリングする
                const { svg } = await mermaid.render(id, source);
                const wrapper = document.createElement('div');
                wrapper.className = 'mermaid';
                wrapper.dataset.mermaidSource = source;
                wrapper.innerHTML = svg;
                pre.parentNode?.replaceChild(wrapper, pre);
            } catch (error) {
                // エラーが発生した場合、エラーメッセージを表示する
                const msg = document.createElement('pre');
                msg.className = 'mermaid-error';
                msg.textContent = `Mermaid rendering failed: ${(error as Error).message}`;
                pre.parentNode?.replaceChild(msg, pre);
                console.error('Mermaid rendering failed:', error);
            }
        }
    }

    /**
     * Mermaid図をレンダリングする関数
     */
    async function renderer() {
        mermaid.initialize({
            startOnLoad: false,
            theme: getTheme(),
            securityLevel: 'loose'
        });
        const diagrams = document.querySelectorAll('.mermaid');
        for (const diagram of diagrams) {
            // データ属性からソースを取得する
            const source = (diagram as HTMLElement).dataset.mermaidSource;
            if (!source) continue;
            const id = `mermaid-${counter++}`;
            try {
                // Mermaid図をレンダリングする
                const { svg } = await mermaid.render(id, source);
                const next = document.createElement('div');
                next.className = 'mermaid';
                next.dataset.mermaidSource = source;
                next.innerHTML = svg;
                diagram.parentNode?.replaceChild(next, diagram);
            } catch (error) {
                console.error('Mermaid rendering failed:', error);
            }
        }
    }

    renderAll();
    // テーマ切り替え時にレンダリングする
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
        setTimeout(renderer, 0);
    });
</script>