---
interface Props {
    id: string
}
const { id } = Astro.props
---
<div class="footnote-item" id={`fn-${id}`}>
    <span class="footnote-number">[{id}]</span>
    <span class="footnote-text">
        <slot />
        <a href={`#fnref-${id}`} class="footnote-back" >↩</a>
    </span>
</div>
<style>
    .footnote-item {
        scroll-margin-top: calc(var(--header-height) + 24px);
        transition: background 0.3s;
    }
    .footnote-item:target {
        background-color: var(--color-bg-secondary);
        border-radius: var(--radius-sm);
        padding: 4px 8px;
        margin: -4px -8px;
    }
    .footnote-number {
        font-weight: 700;
        margin-right: 4px;
    }
    .footnote-back {
        font-size: 0.85em;
        text-decoration: none;
        color: var(--color-text-muted);
    }
</style>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll<HTMLElement>('.footnote-back').forEach(function(back) {
            back.addEventListener('click', function(e) {
                var href = back.getAttribute('href');
                var refEl = href ? document.querySelector(href) : null;
                if (!refEl) return;
                e.preventDefault();
                refEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });
    });
</script>