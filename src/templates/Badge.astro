---
interface Props {
    label: string
    color?: string
    href?: string
}
const { label, color, href } = Astro.props
---
{href ? (
    <a href={href} class={`badge badge-${color}`} style={`--badge-color: ${color || '#667eea'}`}>
        {label}
    </a>
) : (
    <span class={`badge badge-${color}`} style={`--badge-color: ${color || '#667eea'}`}>
        {label}
    </span>
)}

<style>
    .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.75em;
        font-weight: 600;
    }
    .badge-blue {
        background-color: #dbeafe;
        color: #1d4ed8;
    }
    .badge-green {
        background-color: #d1fae5;
        color: #065f46;
    }
    .badge-yellow {
        background-color: #fef3c7;
        color: #92400e;
    }
    .badge-red {
        background-color: #fee2e2;
        color: #991b1b;
    }
    .badge-purple {
        background-color: #e9d5ff;
        color: #6b21a8;
    }
    .badge-gray {
        background-color: #f3f4f6;
        color: #374151;
    }

    :root[data-theme="dark"] {
        .badge-blue {
            background-color: #1e40af;
            color: #dbeafe;
        }
        .badge-green {
            background-color: #064e3b;
            color: #d1fae5;
        }
        .badge-yellow {
            background-color: #92400e;
            color: #fef3c7;
        }
        .badge-red {
            background-color: #991b1b;
            color: #fee2e2;
        }
        .badge-purple {
            background-color: #6b21a8;
            color: #e9d5ff;
        }
        .badge-gray {
            background-color: #374151;
            color: #f3f4f6;
        }
    }
</style>