---
import { undefined } from 'astro:schema';

interface Props {
    label: string
    color?: 'blue' | 'green' | 'yellow' | 'red' | 'purple' | 'gray' | (string & {})
    href?: string
}

const NAMED_COLORS = new Set(['blue', 'green', 'yellow', 'red', 'purple', 'gray']);
const { label, color = '#667eea', href } = Astro.props;
const isNamed = NAMED_COLORS.has(color);
const badgeCls = `badge ${isNamed ? `badge-${color}` : `badge-custom`}`;
const badgeSty = !isNamed ? `--badge-color: ${color}` : undefined;
---
{href
    ? <a href={href} class={badgeCls} style={badgeSty}>{label}</a>
    : <span class={badgeCls} style={badgeSty}>{label}</span>
}

<style>
    .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.75em;
        font-weight: 600;
    }
    /* 定義済みカラー */
    .badge-blue { background-color: #dbeafe; color: #1d4ed8; }
    .badge-green { background-color: #d1fae5; color: #065f46; }
    .badge-yellow { background-color: #fef3c7; color: #92400e; }
    .badge-red { background-color: #fee2e2; color: #991b1b; }
    .badge-purple { background-color: #e9d5ff; color: #6b21a8; }
    .badge-gray { background-color: #f3f4f6; color: #374151; }

    /* カスタムカラー */
    .badge-custom {
        background-color: transparent;
        color: var(--badge-color, #374151);
        border: 1.5px solid var(--badge-color, #374151);
    }

    /* ダークモード */
    :root[data-theme="dark"] .badge-blue { background-color: #1e40af; color: #dbeafe; }
    :root[data-theme="dark"] .badge-green { background-color: #064e3b; color: #d1fae5; }
    :root[data-theme="dark"] .badge-yellow { background-color: #92400e; color: #fef3c7; }
    :root[data-theme="dark"] .badge-red { background-color: #991b1b; color: #fee2e2; }
    :root[data-theme="dark"] .badge-purple { background-color: #6b21a8; color: #e9d5ff; }
    :root[data-theme="dark"] .badge-gray { background-color: #374151; color: #f3f4f6; }
</style>