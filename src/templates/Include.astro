---
import { getEntry, render } from "astro:content";
import { resolveSlug } from "@lib/slug/slugCore";
import { buildSlugMapSync } from "@lib/slug/slugmap";
import { defaultLocale, locales, type Locale } from "@i18n/i18n.config";
import { isInChain, withIncludeChain } from "@lib/includeChain";

interface Props {
    slug: string
    locale?: Locale
}
const { slug, locale } = Astro.props

if (!slug) {
    throw new Error("slug is required")
}

const baseUrl = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '')
const requestedLocale = locales.includes(locale as Locale)
    ? locale as Locale
    : locales.includes(Astro.params.locale as Locale)
        ? Astro.params.locale as Locale
        : defaultLocale

const slugMap = buildSlugMapSync()
const baseSlug = resolveSlug(slug, slugMap)

const currentRouteSlug = typeof Astro.params.slug === "string" && Astro.params.slug.length > 0
    ? Astro.params.slug
    : "index";
const normalizeWikiSlug = (value: string) => value.replace(/\/index$/, "") || "index";
const isSelfInclude = normalizeWikiSlug(currentRouteSlug) === normalizeWikiSlug(baseSlug);

let entry = isSelfInclude ? undefined : await getEntry('wiki', `${requestedLocale}/${baseSlug}`)
if (!entry && requestedLocale !== defaultLocale) {
    entry = await getEntry('wiki', `${defaultLocale}/${baseSlug}`)
}
if (!entry) {
    entry = await getEntry('wiki', baseSlug)
}

let Content: any = null
let resolvedFullSlug = "";
if (entry) {
    const rendered = await render(entry)
    Content = rendered.Content
    resolvedFullSlug = entry.id
}

let wikiUrl = "";
if (entry) {
    const resolvedParts = resolvedFullSlug.split('/');
    const entryLocale = resolvedParts[0];
    const entryBaseSlug = resolvedParts.slice(1).join('/');
    wikiUrl = `${baseUrl}/${entryLocale}/wiki/${entryBaseSlug.replace(/\/index$/, "")}`;
}

const isCircular = entry && isInChain(entry.id);
if (entry && !isCircular) {
    const rendered = await withIncludeChain(entry.id, () => render(entry));
    Content = rendered.Content;
    resolvedFullSlug = entry.id;
}
---
{isSelfInclude && (
    <span class="include-error">
        include skipped self reference: {slug}
    </span>
)}

{!isSelfInclude && !entry && (
    <span class="include-error">
        include not found: {slug}
    </span>
)}

{!isSelfInclude && entry && Content && (
    <div class="transclusion">
        <div class="transclusion-header">
            <a href={wikiUrl}>{slug}</a>
        </div>
        <div class="transclusion-body">
            <Content />
        </div>
    </div>
)}

{isCircular && (
    <span class="include-error">
        include skipped circular reference: {slug}
    </span>
)}

<style>
    .include-error {
        display: inline-block;
        padding: 2px 8px;
        background-color: var(--color-bg-secondary);
        color: var(--color-accent);
        border: 1px dashed var(--color-border);
        border-radius: var(--radius-sm);
        font-size: 0.8rem;
        font-family: var(--font-mono);
    }
    .transclusion {
        border: 1px solid var(--color-border);
        border-radius: 8px;
        margin: 20px 0;
        overflow: hidden;
    }    
    .transclusion-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background-color: var(--color-bg-secondary);
        font-size: 0.78rem;
        color: var(--color-text-subtle);
    }
    .transclusion-header a {
        font-weight: 600;
        color: var(--color-link);
        text-decoration: none;
    }
    .transclusion-header a:hover {
        text-decoration: underline;
    }
    .transclusion-body {
        padding: 16px 20px;
        font-size: 0.9rem;
    }
    .transclusion-body > *:first-child {
        margin-top: 0;
    }
    .transclusion-body > *:last-child {
        margin-bottom: 0;
    }
</style>
