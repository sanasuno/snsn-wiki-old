---
import { navboxes } from "@data/navboxes";

interface Props {
    id: string
}
const { id } = Astro.props

const navbox = navboxes[id]

function escapeHtml(s: string): string {
    return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function renderLinks(links: typeof navbox.rows[number]['links']): string {
    return links.map((link, i) => {
        const target = link.external ? ' target="_blank" rel="noopener"' : '';
        const sep = i < links.length - 1 ? '<span class="navbox-sep"> ・ </span>' : '';
        return `<a href="${escapeHtml(link.href)}"${target}>${escapeHtml(link.text)}</a>${sep}`;
    }).join('');
}
---
{!navbox && (
    <span class="navbox-error">
        Navbox not found: {id}
    </span>
)}
{navbox && (
    <div class="navbox">
        <div class="navbox-title">
            {navbox.icon && <i class={navbox.icon} />}
            {navbox.titleHref
                ? <a href={navbox.titleHref}>{navbox.title}</a>
                : <span>{navbox.title}</span>
            }
        </div>
        <div class="navbox-body">
            {navbox.rows.map(row => (
                <div class="navbox-row">
                    <div class="navbox-label">{row.label}</div>
                    <div class="navbox-links" set:html={renderLinks(row.links)} />
                </div>
            ))}
        </div>
    </div>
)}
<style>
    .navbox-error {
        display: inline-block;
        padding: 2px 8px;
        background-color: var(--color-bg-secondary);
        color: var(--color-accent);
        border: 1px dashed var(--color-border);
        border-radius: var(--radius-sm);
        font-size: 0.8rem;
        font-family: var(--font-mono);
    }
    .navbox {
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        margin: 1.5rem 0;
        overflow: hidden;
        font-size: 0.875rem;
    }
    .navbox-title {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background-color: var(--color-accent);
        color: var(--color-text);
        font-weight: 700;
        font-size: 0.85rem;
    }
    .navbox-title a {
        color: var(--color-text);
        text-decoration: none;
        opacity: 0.9;
    }
    .navbox-title a:hover {
        opacity: 1;
        text-decoration: underline;
    }
    .navbox-body {
        display: table;
        width: 100%;
        border-collapse: collapse;
    }
    .navbox-row {
        display: table-row;
    }
    .navbox-row:not(:last-child) .navbox-label,
    .navbox-row:not(:last-child) .navbox-links {
        border-bottom: 1px solid var(--color-border);
    }
    .navbox-label {
        display: table-cell;
        padding: 8px 14px;
        font-weight: 600;
        color: var(--color-text-muted);
        background-color: var(--color-bg-secondary);
        border-right: 1px solid var(--color-border);
        font-size: 0.8rem;
        white-space: nowrap;
        width: 1%;
        vertical-align: middle;
    }
    .navbox-links {
        display: table-cell;
        padding: 8px 14px;
        vertical-align: middle;
    }
    .navbox-links a {
        color: var(--color-link);
        text-decoration: none;
    }
    .navbox-links a:hover {
        text-decoration: underline;
    }
    .navbox-sep {
        color: var(--color-text-subtle);
    }
    @media (max-width: 600px) {
        .navbox-row {
            flex-direction: column;
        }
        .navbox-label {
            border-right: none;
            border-bottom: 1px solid var(--color-border);
        }
    }
</style>