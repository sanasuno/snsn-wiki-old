---
interface Props {
    cols?: number
}
const { cols } = Astro.props
---
<div class="columns" style={cols ? `--cols:${cols}` : undefined}>
    <slot />
</div>
<style>
    .columns {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin: 1.25em 0;
    }
</style>