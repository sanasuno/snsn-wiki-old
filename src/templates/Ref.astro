---
interface Props {
    id: string
}
const { id } = Astro.props
---
<sup class="fn-ref" id={`fnref-${id}`}>
    <a href={`#fn-${id}`} class="fn-ref-link" data-fn-id={id}>{id}</a>
    <span class="fn-popup" role="tooltip"></span>
</sup>
<style>
    .fn-ref {
        position: relative;
        font-size: 0.75em;
        vertical-align: super;
        line-height: 1;
    }

    .fn-ref-link {
        color: var(--color-accent);
        text-decoration: none;
        font-weight: 700;
        padding: 0 2px;
    }

    .fn-ref-link:hover {
        text-decoration: underline;
    }

    .fn-popup {
        display: none;
        position: absolute;
        bottom: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        width: max-content;
        max-width: 260px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 8px 12px;
        font-size: 0.85rem;
        line-height: 1.5;
        color: var(--color-text);
        box-shadow: var(--shadow-lg);
        z-index: 300;
        white-space: normal;
        font-weight: 400;
        pointer-events: none;
    }

    .fn-popup::after {
        content: '';
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
        border-top-color: var(--color-border);
    }

    .fn-ref:hover .fn-popup {
        display: block;
    }
</style>