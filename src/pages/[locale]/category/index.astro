---
/**
 * pages/[lang]/category/index.astro
 * カテゴリ一覧ページ
 */
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import MainLayout from '@layouts/MainLayout.astro';
import { t, tCategory, locales, formatDate, type Locale } from '@i18n/i18n.config';
import { getRoute, removeTrailingSlash } from '@lib/path';
import { getCategoryFromId } from '@lib/content/category';
import { getUniquePagesByLocale } from '@lib/content/pages';

export const getStaticPaths = () => {
	return locales.map((locale) => ({
		params: { locale },
	}));
};

const locale = Astro.params.locale as Locale;
const baseUrl = removeTrailingSlash(import.meta.env.BASE_URL);
const localeBaseUrl = `${baseUrl}/${locale}`;
const wikiBaseUrl = `${localeBaseUrl}/wiki`;
const allPages = await getCollection('wiki', (p) => !p.data.draft && !p.data.hidden);

const alternateLinks = locales.map((locale) => ({
	locale: locale,
	url: getRelativeLocaleUrl(locale, '/category'),
}));

const pages = getUniquePagesByLocale(allPages, locale);

const categoryMap: Record<string, typeof pages> = {};
for (const page of pages) {
	const category = getCategoryFromId(page.id);
	if (category.length > 0) {
		const topCategory = category[0];
		if (!categoryMap[topCategory]) categoryMap[topCategory] = [];
		categoryMap[topCategory].push(page);
	}
}

const sortedCategories = Object.entries(categoryMap).sort(([a], [b]) => 
	a.localeCompare(b, locale)
);

---

<MainLayout 
	title={t('category.title', locale)} 
	description={t('category.description', locale)}
	locale={locale}
	alternateLinks={alternateLinks}
	isWikiPage={false}
	showMeta={false}
>
	<div class="specialpage-title">
		<h1>
			<i class="fa-solid fa-folder" />
			<span data-i18n="category.title">
				{t('category.title', locale)}
			</span>
		</h1>
		<div class="specialpage-description">
			{Object.keys(categoryMap).length} {t('category.count', locale)}, {pages.length} {t('category.count.page', locale)}
		</div>
	</div>

	<div class="index-page">
		{sortedCategories.map(([cat, catPages]) => (
			<section>
				<a href={`${localeBaseUrl}/category/${encodeURIComponent(cat)}`} class="index-page-category">
					<i class="fa-solid fa-folder" />
					{tCategory(cat, locale)}
					<span>({catPages.length} {t('category.count.page', locale)})</span>
				</a>
				<ul class="index-list">
					{catPages.slice(0, 5).map(page => {
						const updated = page.data.updated || page.data.date || new Date(0);
						const isUpdated = !!page.data.updated;
						return (
							<li class="index-page-item">
								<div class="index-page-item-header">
									<div class="index-page-item-title">
										<a href={getRoute(page.id, wikiBaseUrl)} class="index-file">
											<i class="fa-regular fa-file-lines" />
											{page.data.title}
										</a>
										{page.data.tags && (
											<div class="index-tags">
												{page.data.tags.map((tag: string) => (
													<a href={`${localeBaseUrl}/tag/${encodeURIComponent(tag)}`} class="index-tag">
														#{tag}
													</a>
												))}
											</div>
										)}
									</div>
									{page.data.description && (
										<p class="index-description">
											{page.data.description}
										</p>
									)}
								</div>
								<div class="index-page-item-content">
									<p class="index-updated-date">
										<i class={`${isUpdated ? 'fa-solid fa-clock-rotate-left' : 'fa-regular fa-calendar-plus'}`} />
										{formatDate(updated, locale)}
									</p>
								</div>
							</li>
						)
					})}
					{catPages.length > 5 && (
						<li>
							<a href={`${localeBaseUrl}/category/${encodeURIComponent(cat)}`} class="index-more">
								{t('category.more', locale)} {catPages.length - 5} {t('category.count.page', locale)}
							</a>
						</li>
					)}
				</ul>
			</section>
		))}
	</div>
</MainLayout>
