---
/**
 * src/pages/[locale]/recent.astro
 * 最近更新ページ
 */
import MainLayout from "@layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { t, locales, formatDate, type Locale } from "@i18n/i18n.config";
import { removeTrailingSlash } from "@lib/path";
import { getRoute } from "@lib/path";
import { getUniquePagesByLocale } from "@lib/pages";

export const getStaticPaths = () => {
	return locales.map((locale) => ({
		params: { locale },
	}));
};

const locale = Astro.params.locale as Locale;
const baseUrl = removeTrailingSlash(import.meta.env.BASE_URL);
const localeBaseUrl = `${baseUrl}/${locale}`;
const wikiBaseUrl = `${localeBaseUrl}/wiki`;
const allPages = await getCollection('wiki', (p) => !p.data.draft && !p.data.hidden);

const alternateLinks = locales.map((locale) => ({
	locale: locale,
	url: getRelativeLocaleUrl(locale, '/recent'),
}));

const uniquePages = getUniquePagesByLocale(allPages, locale);
const pages: typeof allPages = Object.values(uniquePages);

const sortedPages = pages.sort((a, b) => {
    const aDate = a.data.updated?.getTime() || a.data.date?.getTime() || 0;
    const bDate = b.data.updated?.getTime() || b.data.date?.getTime() || 0;
    return bDate - aDate;
});
---
<MainLayout
    title={t('recent.title', locale)}
    description={t('recent.description', locale)}
    locale={locale}
    alternateLinks={alternateLinks}
    isWikiPage={false}
    showMeta={false}
>
    <!-- 特殊ページのタイトルと説明 -->
    <div class="specialpage-title">
        <h1>
            <i class="fa-solid fa-clock-rotate-left" />
            <span data-i18n="recent.title">
                {t('recent.title', locale)}
            </span>
        </h1>
        <span class="specialpage-description">
            {t('recent.description', locale)}
        </span>
    </div>
    
    <!-- 最近更新されたページの一覧 -->
    <div class="index-page">
        {sortedPages.map((page) => {
            const updated = page.data.updated || page.data.date || new Date(0);
            const isUpdated = !!page.data.updated;
            return (
            <section>
                <ul class="index-list">
                    <li class="index-page-item">
                        <div class="index-page-item-header">
                            <div class="index-page-item-title">
                                <a href={getRoute(page.id, wikiBaseUrl)} class="index-file">
                                    <i class="fa-regular fa-file-lines" />
                                    {page.data.title}
                                </a>
                                {page.data.tags && (
                                    <div class="index-tags">
                                        {page.data.tags.map((tag: string) => (
                                            <a href={`${localeBaseUrl}/tag/${encodeURIComponent(tag)}`} class="index-tag">
                                                #{tag}
                                            </a>
                                        ))}
                                    </div>
                                )}
                            </div>
                            {page.data.description && (
                                <p class="index-description">
                                    {page.data.description}
                                </p>
                            )}
                        </div>
                        <div class="index-page-item-content">
                            <p class="index-updated-date">
                                <i class={`${isUpdated ? 'fa-solid fa-clock-rotate-left' : 'fa-regular fa-calendar-plus'}`} />
                                {formatDate(updated, locale)}
                            </p>
                        </div>
                    </li>
                </ul>
            </section>
            );
        })}
    </div>
</MainLayout>

