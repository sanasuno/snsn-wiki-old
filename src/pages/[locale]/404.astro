---
/**
 * src/pages/[locale]/404.astro
 */
import MainLayout from "@layouts/MainLayout.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { t, locales, type Locale } from '@i18n/i18n.config';
import { removeTrailingSlash } from "@lib/path";

interface Props {
    locale: Locale;
}

// 404ページの静的パスを生成
export const getStaticPaths = () => {
	return locales.map((locale) => ({
		params: { locale },
        props: { locale },
	}));
};

const locale = Astro.props.locale;
const localeBaseUrl = `${removeTrailingSlash(import.meta.env.BASE_URL)}/${locale}`;

const alternateLinks = locales.map((loc) => ({
	locale: loc,
	url: getRelativeLocaleUrl(loc, '/404'),
}));
---
<MainLayout
    title={t("404.title", locale)}
    description={t("404.description", locale)}
    locale={locale}
    alternateLinks={alternateLinks}
    showMeta={false}
    isWikiPage={false}
>
    <div class="error-container">
        <div class="error-code">
            404
        </div>
        <h1 class="error-heading">
            {t("404.description", locale)}
        </h1>
        <p class="error-message">
            {t("404.message", locale)}
        </p>
        
        <div class="error-actions">
            <a href={localeBaseUrl} class="btn btn-primary">
                <i class="fa-solid fa-house" />
                {t("404.backHome", locale)}
            </a>
            <a href={`${localeBaseUrl}/search`} class="btn btn-secondary">
                <i class="fa-solid fa-magnifying-glass" />
                {t("404.search", locale)}
            </a>
        </div>

        <div class="error-hint">
            <i class="fa-solid fa-circle-info" />
            {t("404.wikiLinkHint", locale)}
        </div>
    </div>
</MainLayout>
