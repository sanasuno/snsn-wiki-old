---
/**
 * pages/[lang]/index.astro
 * ホームページ
 */
import { getRelativeLocaleUrl } from 'astro:i18n';
import MainLayout from '@layouts/MainLayout.astro';
import { t, locales, type Locale } from '@i18n/i18n.config';

export const getStaticPaths = () => {
	return locales.map((locale) => ({
		params: { locale },
	}));
};

const locale = Astro.params.locale as Locale;

const alternateLinks = locales.map((locale) => ({
	locale: locale,
	url: getRelativeLocaleUrl(locale, '/'),
}));

---

<MainLayout 
	title={t('home.title', locale)} 
	description={t('home.description', locale)}
	locale={locale}
	alternateLinks={alternateLinks}
>

	<div>{locale}</div>
</MainLayout>
