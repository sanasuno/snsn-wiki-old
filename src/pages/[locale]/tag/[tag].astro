---
/**
 * src/pages/[locale]/category/[...category].astro
 * カテゴリページ
 */
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import MainLayout from '@layouts/MainLayout.astro';
import { t, locales, formatDate, type Locale } from '@i18n/i18n.config';
import { getRoute, removeTrailingSlash } from '@lib/path';
import { getUniquePagesByLocale } from '@lib/content/pages';

export async function getStaticPaths() {
	const pages = await getCollection('wiki', (p) => !p.data.draft && !p.data.hidden);
    const tagMap: Record<string, typeof pages> = {};
    for (const page of pages) {
        for (const tag of page.data.tags || []) {
            if (!tagMap[tag]) {
                tagMap[tag] = [];
            }
            tagMap[tag].push(page);
        }
    }
    const paths = [];
    for (const locale of locales) {
        for (const [tag, tagPages] of Object.entries(tagMap)) {
            paths.push({
                params: { locale, tag },
                props: { locale, tag, tagPages },
            });
        }
    }
    return paths;
}

const locale = Astro.params.locale as Locale;
const { tag, tagPages } = Astro.props;

const baseUrl = removeTrailingSlash(import.meta.env.BASE_URL);
const localeBaseUrl = `${baseUrl}/${locale}`;
const wikiBaseUrl = `${localeBaseUrl}/wiki`;

const filterTag = tag.split('/');
const tagLabel = filterTag[filterTag.length - 1];

// ロケール優先で重複排除
const sortedPages = getUniquePagesByLocale(tagPages, locale).sort((a, b) =>
    a.data.title.localeCompare(b.data.title)
);

const alternateLinks = locales.map((loc) => ({
	locale: loc,
	url: getRelativeLocaleUrl(loc, `/tag/${tag}`),
}));
---
<MainLayout
    title={t("tag.title", locale)}
    description={`${t("tag.description", locale)} - ${tagLabel}`}
    locale={locale}
    alternateLinks={alternateLinks}
    showMeta={false}
    isWikiPage={false}
>
    <!-- タグページのタイトルと説明 -->
	<div class="specialpage-title">
        <div class="specialpage-back">
            <a href={`${localeBaseUrl}/tag`}>
                <i class="fa-solid fa-arrow-left" />
                {t('tag.title', locale)}
            </a>
        </div>
		<h1 class="index-title">
			<i class="fa-solid fa-tags" />
            <span>#{tag}</span>
		</h1>
		<div class="specialpage-description">
			{sortedPages.length} {t('tag.count.page', locale)}
		</div>
	</div>

    <!-- タグページのコンテンツ -->
    <div class="index-page">
        {sortedPages.length > 0 && (
            <ul>
                {sortedPages.map(page => {
                    const updated = page.data.updated || page.data.date || new Date(0);
                    const isUpdated = !!page.data.updated;
                    return (
                        <li class="index-page-item">
                            <div class="index-page-item-header">
                                <div class="index-page-item-title">
                                    <a href={getRoute(page.id, wikiBaseUrl)} class="index-file">
                                        <i class="fa-regular fa-file-lines" />
                                        {page.data.title}
                                    </a>
                                    {page.data.tags && (
                                        <div class="index-tags">
                                            {page.data.tags.map((tag: string) => (
                                                <a href={`${localeBaseUrl}/tag/${encodeURIComponent(tag)}`} class="index-tag">
                                                    #{tag}
                                                </a>
                                            ))}
                                        </div>
                                    )}
                                </div>
                                {page.data.description && (
                                    <p class="index-description">
                                        {page.data.description}
                                    </p>
                                )}
                            </div>
                            <div class="index-page-item-content">
                                <p class="index-updated-date">
                                    <i class={`${isUpdated ? 'fa-solid fa-clock-rotate-left' : 'fa-regular fa-calendar-plus'}`} />
                                    {formatDate(updated, locale)}
                                </p>
                            </div>
                        </li>
                    );
                })}
            </ul>
        )}
    </div>
</MainLayout>