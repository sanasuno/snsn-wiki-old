---
/**
 * src/pages/[locale]/search.astro
 */
import { t, locales, type Locale } from '@i18n/i18n.config';
import MainLayout from '@layouts/MainLayout.astro';
import { removeTrailingSlash } from '@lib/path';
import type { GetStaticPathsResult } from 'astro';

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
    return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const baseUrl = removeTrailingSlash(import.meta.env.BASE_URL);

const label = {
    pageTitle:   t('search.title',       locale),
    placeholder: t('search.placeholder', locale),
    description: t('search.description', locale),
};

const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';
const alternateLinks = locales.map((l) => ({
    locale: l,
    url: `${siteUrl}${baseUrl}/${l}/search`,
}));
---

<MainLayout
    title={label.pageTitle}
    description={label.description}
    locale={locale}
    alternateLinks={alternateLinks}
    isWikiPage={false}
    showMeta={false}
>
    <!-- data-* 属性でサーバー値をクライアントに渡す -->
    <div
        id="search-root"
        class="search-page"
        data-locale={locale}
        data-base-url={baseUrl}
    >
        <!-- 特殊ページのタイトルと説明 -->
        <div class="specialpage-title">
            <h1>
                <i class="fa-solid fa-magnifying-glass" style="color: var(--color-accent); margin-right: 0.4em;"></i>
                {label.pageTitle}
            </h1>
            <p class="specialpage-description">{label.description}</p>
        </div>

        <!-- 検索バー -->
        <div class="sp-search-bar">
            <i class="fa-solid fa-magnifying-glass sp-search-icon"></i>
            <input
                id="sp-input"
                class="sp-search-input"
                type="search"
                placeholder={label.placeholder}
                autocomplete="off"
                spellcheck="false"
                autofocus
            />
            <button id="sp-clear" class="sp-clear-btn" aria-label="clear" hidden>
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <!-- 検索結果 -->
        <p id="sp-status" class="sp-status" aria-live="polite" hidden></p>
        <ul id="sp-results" class="sp-results" role="list"></ul>
    </div>
</MainLayout>

<style is:global>
.sp-search-bar {
    position: relative;
    display: flex;
    align-items: center;
    margin-bottom: 20px;
}

.sp-search-icon {
    position: absolute;
    left: 14px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    pointer-events: none;
}

.sp-search-input {
    width: 100%;
    padding: 12px 44px 12px 40px;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg, 10px);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 1rem;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition);
}

.sp-search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-light, rgba(99,102,241,0.12));
}

.sp-search-input::-webkit-search-cancel-button {
    display: none;
}

.sp-clear-btn {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    padding: 4px 6px;
    border-radius: var(--radius-sm);
    transition: background var(--transition), color var(--transition);
    display: flex;
    align-items: center;
}

.sp-clear-btn:hover {
    background: var(--color-bg-hover);
    color: var(--color-text);
}

.sp-status {
    font-size: 0.825rem;
    color: var(--color-text-muted);
    margin: 0 0 16px;
    display: flex;
    align-items: center;
    gap: 6px;
}

.sp-results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.sp-result-item a {
    display: block;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background var(--transition), transform var(--transition);
}

.sp-result-item a:hover {
    border-color: var(--color-accent);
    background: var(--color-bg-hover);
    transform: translateX(2px);
}

.sp-result-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 5px;
    display: flex;
    align-items: center;
    gap: 7px;
}

.sp-result-title i {
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    flex-shrink: 0;
}

.sp-result-title mark,
.sp-result-excerpt mark {
    background: var(--color-accent-light, rgba(99,102,241,0.15));
    color: var(--color-accent);
    border-radius: 2px;
    padding: 0 2px;
    font-weight: 700;
}

.sp-result-excerpt {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.sp-result-url {
    margin-top: 5px;
    font-size: 0.7rem;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
}

.sp-empty {
    padding: 48px 0;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    list-style: none;
}

.sp-empty i {
    font-size: 2rem;
    color: var(--color-text-subtle);
}

.sp-loading {
    padding: 48px 0;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    list-style: none;
}
</style>

<script>
import { t, defaultLocale, type Locale } from "@i18n/i18n.config";
import { highlight, extractSnippet, search } from '@scripts/search';
import type { SearchEntry } from "@scripts/search";

// define:vars を使わず data-* 属性から値を取得
const root    = document.getElementById('search-root')!;
const locale: Locale = (root.dataset.locale  ?? defaultLocale) as Locale;
const baseUrl = root.dataset.baseUrl ?? '';

const DEBOUNCE_MS   = 150; // 検索のデバウンス時間（ミリ秒）
const MAX_RESULTS   = 50; // 最大表示結果数
const CONTEXT_CHARS = 80; // コンテキスト文字数

const input    = document.getElementById('sp-input')    as HTMLInputElement; // 検索入力フィールド
const results  = document.getElementById('sp-results')  as HTMLUListElement; // 検索結果リスト
const statusEl = document.getElementById('sp-status')   as HTMLParagraphElement; // ステータスメッセージ
const clearBtn = document.getElementById('sp-clear')    as HTMLButtonElement; // クリアボタン

let index: SearchEntry[] | null = null;
let debounceTimer: ReturnType<typeof setTimeout> | null = null;

// ---- URL パラメータ同期 ----
/**
 * URLのクエリパラメータから検索キーワードを取得
 * @returns 検索キーワード
 */
function getQueryParam(): string {
    return new URLSearchParams(window.location.search).get('q') ?? '';
}

/**
 * URLのクエリパラメータを設定
 * @param q 検索キーワード
 */
function setQueryParam(q: string) {
    const url = new URL(window.location.href);
    // 検索キーワードを設定または削除
    q ? url.searchParams.set('q', q) : url.searchParams.delete('q');
    window.history.pushState({}, '', url.toString());
}

// ---- インデックスロード ----
/**
 * インデックスを確保し、ロードする
 */
async function ensureIndex() {
    if (index) return;
    showLoading();
    try {
        // 検索インデックスをロードし、パースする
        const res = await fetch(`${baseUrl}/search-index.${locale}.json`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        index = await res.json();
    } catch (e) {
        console.error('[Search] index load failed:', e);
        showError();
    }
}

// ---- 描画 ----
/**
 * 検索結果を描画する
 * @param entries 検索結果の配列
 * @param query 検索キーワード
 */
function renderResults(entries: SearchEntry[], query: string) {
    results.innerHTML = '';
    // 検索結果が空の場合、ステータスを表示して終了
    if (!entries.length) {
        showStatus('empty');
        return;
    }
    const count = entries.length;
    const countLabel = `${count} ${t('search.countlabel', locale)}`;
    showStatusText(`<i class="fa-solid fa-check" style="color:var(--color-accent)" /> ${countLabel}`);

    // 検索結果を描画
    for (const entry of entries) {
        const snippet = extractSnippet(entry.body, query.trim(), CONTEXT_CHARS);
        const li = document.createElement('li');
        li.className = 'sp-result-item';
        const a = document.createElement('a');
        a.href = `${baseUrl}${entry.url}`;
        a.innerHTML = `
            <div class="sp-result-title">
                <i class="fa-regular fa-file-lines"></i>
                ${highlight(entry.title, query.trim())}
            </div>
            <div class="sp-result-excerpt">${highlight(snippet, query.trim())}</div>
            <div class="sp-result-url">${entry.url}</div>
        `;
        li.appendChild(a);
        results.appendChild(li);
    }
}

/**
 * ステータスを表示する
 * @param html HTML文字列
 */
function showStatusText(html: string) {
    statusEl.innerHTML = html;
    statusEl.hidden = false;
}

/**
 * 初期状態を表示する
 */
function showInitial() {
    results.innerHTML = '';
    statusEl.hidden = true;
}

/**
 * ローディング状態を表示する
 */
function showLoading() {
    results.innerHTML = `<li class="sp-loading">
        <i class="fa-solid fa-spinner fa-spin" style="margin-right:8px" />
        ${t('search.loading', locale)}
    </li>`;
    statusEl.hidden = true;
}

/**
 * エラー状態を表示する
 */
function showError() {
    results.innerHTML = `<li class="sp-empty">
        <i class="fa-solid fa-circle-exclamation"></i>
        ${t('search.indexError', locale)}
    </li>`;
    statusEl.hidden = true;
}

/**
 * ステータスを表示する
 * @param type ステータスタイプ ('empty')
 */
function showStatus(type: string) {
    if (type === 'empty') {
        results.innerHTML = `<li class="sp-empty">
            <i class="fa-regular fa-face-frown-open"></i>
            ${t('search.noResults', locale)}
        </li>`;
        statusEl.hidden = true;
    }
}

/**
 * 検索を実行する
 * @param query 検索クエリ
 */
async function runSearch(query: string) {
    await ensureIndex();
    if (!index) return;
    renderResults(search(query, index, MAX_RESULTS), query);
}

// ---- イベント ----
/**
 * 初期化する
 */
async function init() {
    const q = getQueryParam();
    // 検索クエリがある場合、検索を実行する
    if (q) {
        input.value = q;
        clearBtn.hidden = false;
        await runSearch(q);
    } else {
        showInitial();
    }
}

/**
 * ページ読み込み時に初期化する
 */
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
} else {
    init();
}

/**
 * ページ遷移時に検索を更新する
 */
window.addEventListener('popstate', () => {
    const q = getQueryParam();
    input.value = q;
    clearBtn.hidden = !q;
    q ? runSearch(q) : showInitial();
});

/**
 * 検索入力時に検索を実行する
 */
input?.addEventListener('input', () => {
    const q = input.value;
    clearBtn.hidden = !q;
    // デバウンス処理
    if (debounceTimer) clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
        setQueryParam(q);
        q.trim() ? runSearch(q) : showInitial();
    }, DEBOUNCE_MS);
});

/**
 * 検索クリアボタンをクリックしたときの処理
 */
clearBtn?.addEventListener('click', () => {
    input.value = '';
    clearBtn.hidden = true;
    setQueryParam('');
    showInitial();
    input.focus();
});

/**
 * キーボードショートカットを処理する
 */
document.addEventListener('keydown', (e) => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    // Ctrl+K または Cmd+K で検索入力にフォーカス
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault(); input?.focus();
    }
    // / で検索入力にフォーカス
    if (e.key === '/' && tag !== 'INPUT' && tag !== 'TEXTAREA') {
        e.preventDefault(); input?.focus();
    }
});
</script>