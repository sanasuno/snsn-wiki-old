---
/**
 * @layouts/MainLayout.astro
 * サイト全体のレイアウトを定義するファイル
 */
import { t, defaultLocale, type Locale } from '@i18n/i18n.config';
import { removeTrailingSlash } from '@scripts/utils';
import Header from '@components/Header.astro';
import Sidebar from '@components/Sidebar.astro';
import MainContent from '@components/MainContent.astro';
import Toc from '@components/Toc.astro';
import MiniGraph from '@components/MiniGraph.astro';

import '@fortawesome/fontawesome-free/css/all.min.css';
import '@styles/global.css';
import '@styles/theme.css';

interface Props {
    title: string;
    description?: string;
    locale?: Locale;
    alternateLinks?: { locale: Locale; url: string }[];
    headings?: { depth: number; slug: string; text: string }[];
    tags?: string[];
    category?: string;
    date?: Date;
    updated?: Date;
    isFallbackContent?: boolean;
    isWikiPage?: boolean;
}

const {
    title,
    description,
    locale = defaultLocale,
    alternateLinks = [],
    headings = [],
    tags = [],
    category,
    date,
    updated,
    isFallbackContent = false,
    isWikiPage = false,
}: Props = Astro.props;

// 基本URL設定
const currentPath = removeTrailingSlash(Astro.url.pathname) || '/';
const baseUrl = removeTrailingSlash(import.meta.env.BASE_URL);
const localeBaseUrl = `${baseUrl}/${locale}`;
const wikiBaseUrl = `${localeBaseUrl}/wiki`;
const canonicalUrl = Astro.url;

const defaultAlternateLink = alternateLinks.find((link) => link.locale === defaultLocale);

// 目次パネルの表示判定：見出しがある場合に表示
const hasTocPanel = headings.length > 0;

// OGPでの表示名と説明文
const siteTitle = t('site.title', locale) ?? t('site.title', defaultLocale);
const pageTitle = `${title} | ${siteTitle}`;
const siteDescription = t('site.description', locale) ?? t('site.description', defaultLocale);
const pageDescription = description ?? siteDescription;
const ogpImageUrl = new URL('/ogp.png', Astro.site).href;
---
<!DOCTYPE html>
<html lang={locale} data-lang={locale} data-default-locale={defaultLocale}>
    <head prefix="og: http://ogp.me/ns#">
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <meta name="generator" content="snsn-wiki" />
        <link rel="icon" href={`${baseUrl}/favicon.ico`} sizes="48x48" />
        <link rel="icon" href={`${baseUrl}/favicon.svg`} type="image/svg+xml" />
        <link rel="sitemap" href={`${baseUrl}/sitemap-index.xml`} />
        <link rel="canonical" href={canonicalUrl.href} />
        {defaultAlternateLink && (
            <link rel="alternate" hreflang="x-default" href={new URL(defaultAlternateLink.url, Astro.site).href} />
        )}
        {
            alternateLinks.map((link) => (
                <link rel="alternate" hreflang={link.locale} href={new URL(link.url, Astro.site).href} />
            ))
        }
        <!-- OGP -->
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl.href} />
        <meta property="og:image" content={ogpImageUrl} />
        <meta property="og:site_name" content={siteTitle} />
        <meta property="og:locale" content={t('og.locale', locale) ?? t('og.locale', defaultLocale)} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        <meta name="twitter:image" content={ogpImageUrl} />
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Noto+Sans+JP:wght@100..900&family=Noto+Serif+JP:wght@200..900&display=swap" rel="stylesheet">
        <!-- テーマ初期化 -->
        <script is:inline>
            (function() {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark' || savedTheme === 'light') {
                    document.documentElement.setAttribute('data-theme', savedTheme);
                } else if (!savedTheme) {
                    // テーマ未設定の場合はOSの設定を優先
                    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                    document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
                }
            })();
        </script>
        <!-- 言語選択初期化 -->
        <script>
            import { initI18n } from '@scripts/i18n';
            initI18n();
        </script>
    </head>
    <body>
        <div class={`layout${hasTocPanel ? '' : ' no-toc'}`}>
            <!-- ヘッダー -->
            <Header 
                locale={locale} 
                localeBaseUrl={localeBaseUrl} 
                currentPath={currentPath}
            />

            <!-- サイドバー -->
            <Sidebar 
                locale={locale} 
                localeBaseUrl={localeBaseUrl} 
                wikiBaseUrl={wikiBaseUrl}
                currentPath={currentPath}
            />

            <!-- メインコンテンツ -->
            <MainContent 
                title={title} 
                locale={locale}
                localeBaseUrl={localeBaseUrl} 
                currentPath={currentPath}
                category={category}
                tags={tags}
                date={date}
                updated={updated}
                isFallbackContent={isFallbackContent}
                isWikiPage={isWikiPage}
            >
                <slot />
            </MainContent>

            <!-- 目次パネル -->
            {!!isWikiPage && (
            <aside class="toc-panel" id="toc-panel">
                {hasTocPanel && 
                    <Toc 
                        headings={headings} 
                        locale={locale} 
                    />
                }

                <!-- ミニグラフ -->
                <MiniGraph 
                    locale={locale} 
                    localeBaseUrl={localeBaseUrl} 
                    currentPath={currentPath}
                />
            </aside>
            )}
        </div>
        <script>
            import "@scripts/main"
        </script>
    </body>
</html>