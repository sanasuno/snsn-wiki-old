---
/**
 * MainLayout.astro
 * サイト全体のレイアウトを定義するファイル
 * @param _props 
 */
import { t, defaultLocale, type Locale } from '@i18n/i18n.config';
import Header from '@components/Header.astro';
import Sidebar from '@components/Sidebar.astro';
import MainContents from '@components/MainContents.astro';
import Toc from '@components/Toc.astro';
import '@styles/global.css';
import '@styles/theme.css';
import { object } from 'astro:schema';

interface Props {
    title: string;
    description: string;
    locale: Locale;
    alternateLinks?: { locale: Locale; url: string }[];
    headings?: { depth: number; slug: string; text: string }[];
    currentSlug?: string;
}

const {
    title,
    description,
    locale = defaultLocale,
    alternateLinks = [],
    headings = [],
    currentSlug = '',
} = Astro.props;

// 基本URL設定
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const prefixBaseUrl = locale === defaultLocale ? baseUrl : `${baseUrl}/${locale}`;
const canonicalUrl = new URL(prefixBaseUrl, Astro.site);

// 目次パネルの表示判定
// - 見出しがある場合に表示
// - 現在のページがルートページでない場合に表示
const hasTocPanel = headings.length > 1 || !!currentSlug;
---
<!DOCTYPE html>
<html lang={locale}>
    <head prefix="og: http://ogp.me/ns#">
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{title} | {t('site.title', locale) ?? t('site.title', defaultLocale)}</title>
        <meta name="description" content={description ?? t('site.description', locale) ?? t('site.description', defaultLocale)} />
        <meta name="generator" content="snsn-wiki" />
        <link rel="icon" href={`${baseUrl}/favicon.ico`} sizes="48x48" />
        <link rel="icon" href={`${baseUrl}/favicon.svg`} type="image/svg+xml" />
        <link rel="sitemap" href={`${baseUrl}/sitemap-index.xml`} />
        <link rel="canonical" href={canonicalUrl.href} />
        {
            alternateLinks.map((link) => (
                <link rel="alternate" href={link.url} hreflang={link.locale} />
            ))
        }
        <!-- OGP -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description ?? t('site.description', locale) ?? t('site.description', defaultLocale)} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl.href} />
        <meta property="og:image" content={new URL(`${baseUrl}/ogp.png`, Astro.site).href} />
        <meta property="og:site_name" content={t('site.title', locale) ?? t('site.title', defaultLocale)} />
        <meta property="og:locale" content={t('og.locale', locale)} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description ?? t('site.description', locale) ?? t('site.description', defaultLocale)} />
        <meta name="twitter:image" content={new URL(`${baseUrl}/ogp.png`, Astro.site).href} />
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Noto+Sans+JP:wght@100..900&family=Noto+Serif+JP:wght@200..900&display=swap" rel="stylesheet">
    </head>
    <body>
        <div class={`layout${hasTocPanel ? '' : ' no-toc'}`}>
            <!-- ヘッダー -->
            <Header />

            <!-- サイドバー -->
            <Sidebar />

            <!-- メインコンテンツ -->
            <MainContents>
                <slot />
            </MainContents>

            <!-- 目次パネル -->
            {hasTocPanel && <Toc />}
        </div>
        <script src="@scripts/main.js"></script>
    </body>
</html>